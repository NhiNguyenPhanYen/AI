{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyNmKGZoIXDT6/ezmW/3TrVy"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["from heapq import heappush, heappop\n","import copy\n","\n","n = 3\n","\n","rows = [1, 0, -1, 0]\n","cols = [0, -1, 0, 1]\n","\n","\n","\n","class Node:\n","    def __init__(self, parent, mats, empty_pos, cost):\n","        self.parent = parent\n","        self.mats = mats\n","        self.empty_pos = empty_pos\n","        self.cost = cost\n","\n","    def __lt__(self, other):\n","        return self.cost < other.cost\n","\n","\n","\n","def heuristic(mat, goal):\n","    count = 0\n","    for i in range(n):\n","        for j in range(n):\n","            if mat[i][j] != 0 and mat[i][j] != goal[i][j]:\n","                count += 1\n","    return count\n","\n","\n","\n","def isSolvable(mat):\n","    arr = []\n","    for row in mat:\n","        for num in row:\n","            if num != 0:\n","                arr.append(num)\n","\n","    inv = 0\n","    for i in range(len(arr)):\n","        for j in range(i + 1, len(arr)):\n","            if arr[i] > arr[j]:\n","                inv += 1\n","\n","    return inv % 2 == 0\n","\n","\n","def toTuple(mat):\n","    return tuple(tuple(row) for row in mat)\n","\n","\n","def newNode(mat, empty_pos, new_pos, parent, goal):\n","    new_mat = copy.deepcopy(mat)\n","\n","    x1, y1 = empty_pos\n","    x2, y2 = new_pos\n","\n","    new_mat[x1][y1], new_mat[x2][y2] = new_mat[x2][y2], new_mat[x1][y1]\n","\n","    cost = heuristic(new_mat, goal)\n","\n","    return Node(parent, new_mat, [x2, y2], cost)\n","\n","\n","def printMat(mat):\n","    for row in mat:\n","        print(*row)\n","    print()\n","\n","\n","def printPath(node):\n","    if node is None:\n","        return\n","    printPath(node.parent)\n","    printMat(node.mats)\n","\n","\n","\n","def solve(initial, empty_pos, goal):\n","\n","    if not isSolvable(initial):\n","        print(\" Không có nghiệm\")\n","        return\n","\n","    pq = []\n","    visited = set()\n","\n","    root = Node(None, initial, empty_pos, heuristic(initial, goal))\n","    heappush(pq, root)\n","    visited.add(toTuple(initial))\n","\n","    while pq:\n","        cur = heappop(pq)\n","\n","\n","        if cur.cost == 0:\n","            print(\"Tìm thấy lời giải:\\n\")\n","            printPath(cur)\n","            return\n","\n","\n","        for i in range(4):\n","            new_x = cur.empty_pos[0] + rows[i]\n","            new_y = cur.empty_pos[1] + cols[i]\n","\n","            if 0 <= new_x < n and 0 <= new_y < n:\n","                child = newNode(cur.mats, cur.empty_pos,\n","                                [new_x, new_y], cur, goal)\n","\n","                state = toTuple(child.mats)\n","\n","                if state not in visited:\n","                    heappush(pq, child)\n","                    visited.add(state)\n","\n","    print(\"Không tìm thấy lời giải\")\n","\n","initial = [\n","    [1, 2, 3],\n","    [5, 6, 0],\n","    [7, 8, 4]\n","]\n","\n","goal = [\n","    [1, 2, 3],\n","    [5, 6, 4],\n","    [7, 8, 0]\n","]\n","\n","empty_pos = [1, 2]\n","\n","solve(initial, empty_pos, goal)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"DZusbJPdm2vV","executionInfo":{"status":"ok","timestamp":1775734067551,"user_tz":-420,"elapsed":25,"user":{"displayName":"8_ Yến Nhi","userId":"07991773199080732501"}},"outputId":"1e2328fd-b612-4829-d615-f8c8fa8e1b59"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["Tìm thấy lời giải:\n","\n","1 2 3\n","5 6 0\n","7 8 4\n","\n","1 2 3\n","5 6 4\n","7 8 0\n","\n"]}]}]}